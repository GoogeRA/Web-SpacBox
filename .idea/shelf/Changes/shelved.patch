<+>* {\r\n    margin: 0;\r\n    padding: 0;\r\n    box-sizing: border-box;\r\n    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\r\n}\r\n\r\nbody {\r\n    background: linear-gradient(135deg, #0a0a12 0%, #1a1a2e 100%);\r\n    color: #e0e0ff;\r\n    min-height: 100vh;\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: center;\r\n    justify-content: center;\r\n    padding: 20px;\r\n    overflow-x: hidden;\r\n    position: relative;\r\n}\r\n\r\n/* Космический фон */\r\n.cosmic-bg {\r\n    position: fixed;\r\n    top: 0;\r\n    left: 0;\r\n    width: 100%;\r\n    height: 100%;\r\n    background: radial-gradient(\r\n        ellipse at center,\r\n        rgba(15, 15, 30, 0.9) 0%,\r\n        rgba(10, 10, 18, 0.95) 70%,\r\n        rgba(5, 5, 12, 1) 100%\r\n    );\r\n    z-index: -3;\r\n}\r\n\r\n.stars {\r\n    position: fixed;\r\n    top: 0;\r\n    left: 0;\r\n    width: 100%;\r\n    height: 100%;\r\n    z-index: -2;\r\n}\r\n\r\n.star {\r\n    position: absolute;\r\n    background: rgba(255, 255, 255, 0.8);\r\n    border-radius: 50%;\r\n    animation: twinkle 4s infinite;\r\n}\r\n\r\n@keyframes twinkle {\r\n    0%, 100% { opacity: 0.2; transform: scale(1); }\r\n    50% { opacity: 1; transform: scale(1.1); }\r\n}\r\n\r\n.nebula {\r\n    position: fixed;\r\n    border-radius: 50%;\r\n    filter: blur(60px);\r\n    z-index: -1;\r\n    opacity: 0.25;\r\n}\r\n\r\n.nebula-1 {\r\n    top: 15%; left: 10%; width: 400px; height: 400px;\r\n    background: radial-gradient(circle, #9d4edd 0%, transparent 70%);\r\n}\r\n\r\n.nebula-2 {\r\n    bottom: 10%; right: 15%; width: 350px; height: 350px;\r\n    background: radial-gradient(circle, #6366f1 0%, transparent 70%);\r\n}\r\n\r\n.nebula-3 {\r\n    top: 60%; left: 65%; width: 300px; height: 300px;\r\n    background: radial-gradient(circle, #ff5eda 0%, transparent 70%);\r\n}\r\n\r\n/* Заголовок сайта */\r\n.site-header {\r\n    width: 100%;\r\n    max-width: 1200px;\r\n    background: rgba(20, 20, 40, 0.85);\r\n    border: 2px solid rgba(157, 78, 221, 0.6);\r\n    border-radius: 16px;\r\n    padding: 15px 30px;\r\n    margin: 0 auto 30px;\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    box-shadow:\r\n        0 10px 30px rgba(0, 0, 0, 0.5),\r\n        inset 0 0 20px rgba(157, 78, 221, 0.15);\r\n    position: relative;\r\n    z-index: 10;\r\n}\r\n\r\n.site-title {\r\n    color: #ffffff;\r\n    font-size: 1.6rem;\r\n    font-weight: 700;\r\n    letter-spacing: 1px;\r\n    text-transform: uppercase;\r\n    display: flex;\r\n    align-items: center;\r\n}\r\n\r\n.site-title::before {\r\n    content: \"\";\r\n    display: inline-block;\r\n    width: 8px;\r\n    height: 8px;\r\n    background: #10b981;\r\n    border-radius: 50%;\r\n    margin-right: 12px;\r\n    box-shadow: 0 0 8px rgba(16, 185, 129, 0.6);\r\n}\r\n\r\n/* Навигационное меню */\r\n.nav-menu {\r\n    display: flex;\r\n    gap: 25px;\r\n    margin: 0 20px;\r\n}\r\n\r\n.nav-link {\r\n    color: #c5c5e0;\r\n    text-decoration: none;\r\n    font-weight: 500;\r\n    font-size: 1.05rem;\r\n    position: relative;\r\n    padding: 8px 12px;\r\n    transition: all 0.3s ease;\r\n    border-radius: 8px;\r\n}\r\n\r\n.nav-link:hover {\r\n    color: #ffffff;\r\n    background: rgba(157, 78, 221, 0.15);\r\n}\r\n\r\n.nav-link.active {\r\n    color: #ffffff;\r\n    background: rgba(157, 78, 221, 0.25);\r\n    font-weight: 600;\r\n    box-shadow: 0 0 15px rgba(157, 78, 221, 0.3);\r\n}\r\n\r\n.nav-link::after {\r\n    content: '';\r\n    position: absolute;\r\n    bottom: 3px;\r\n    left: 50%;\r\n    transform: translateX(-50%) scaleX(0);\r\n    width: 80%;\r\n    height: 2px;\r\n    background: #9d4edd;\r\n    transition: transform 0.3s ease;\r\n    border-radius: 2px;\r\n}\r\n\r\n.nav-link:hover::after,\r\n.nav-link.active::after {\r\n    transform: translateX(-50%) scaleX(1);\r\n}\r\n\r\n/* Системные кнопки */\r\n.site-controls {\r\n    display: flex;\r\n    gap: 10px;\r\n}\r\n\r\n.control-btn {\r\n    width: 14px;\r\n    height: 14px;\r\n    border-radius: 50%;\r\n    border: 1px solid rgba(255, 255, 255, 0.3);\r\n    transition: all 0.3s ease;\r\n}\r\n\r\n.control-btn.close:hover { background: #ff5252; border-color: #ff1a1a; }\r\n.control-btn.minimize:hover { background: #ffcc00; border-color: #cc9900; }\r\n.control-btn.maximize:hover { background: #2ecc40; border-color: #1a8c26; }\r\n\r\n/* Основной контент */\r\n.main-content {\r\n    width: 100%;\r\n    max-width: 1200px;\r\n    margin: 0 auto;\r\n    position: relative;\r\n    z-index: 5;\r\n}\r\n\r\n/* Заголовок страницы */\r\n.page-title {\r\n    font-size: 2.2rem;\r\n    font-weight: 800;\r\n    letter-spacing: -1px;\r\n    margin: 0 0 25px;\r\n    color: #ffffff;\r\n    text-align: center;\r\n    position: relative;\r\n}\r\n\r\n.page-title::after {\r\n    content: '';\r\n    position: absolute;\r\n    bottom: -15px;\r\n    left: 50%;\r\n    transform: translateX(-50%);\r\n    width: 100px;\r\n    height: 4px;\r\n    background: linear-gradient(90deg, transparent, #9d4edd, transparent);\r\n    border-radius: 2px;\r\n}\r\n\r\n/* Блок конфигуратора */\r\n.configurator-container {\r\n    background: rgba(25, 25, 50, 0.75);\r\n    border-radius: 16px;\r\n    padding: 25px;\r\n    border: 1px solid rgba(157, 78, 221, 0.3);\r\n    box-shadow:\r\n        0 10px 30px rgba(0, 0, 0, 0.35),\r\n        inset 0 0 15px rgba(157, 78, 221, 0.08);\r\n    margin-bottom: 30px;\r\n}\r\n\r\n/* Заголовок блока */\r\n.block-title {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    margin-bottom: 20px;\r\n    padding-bottom: 15px;\r\n    border-bottom: 1px solid rgba(157, 78, 221, 0.3);\r\n}\r\n\r\n.block-title h2 {\r\n    font-size: 1.6rem;\r\n    color: #ffffff;\r\n    font-weight: 600;\r\n}\r\n\r\n.block-title .status {\r\n    background: rgba(157, 78, 221, 0.15);\r\n    color: #9d4edd;\r\n    border: 1px solid rgba(157, 78, 221, 0.3);\r\n    border-radius: 8px;\r\n    padding: 5px 12px;\r\n    font-size: 0.95rem;\r\n    font-weight: 500;\r\n}\r\n\r\n/* Список компонентов - вертикальный */\r\n.component-list {\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: 15px;\r\n}\r\n\r\n.component-item {\r\n    background: rgba(35, 35, 70, 0.65);\r\n    border: 1px solid rgba(157, 78, 221, 0.2);\r\n    border-radius: 10px;\r\n    padding: 18px;\r\n    transition: all 0.3s ease;\r\n    cursor: pointer;\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n}\r\n\r\n.component-item:hover {\r\n    transform: translateY(-3px);\r\n    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);\r\n    border-color: rgba(157, 78, 221, 0.4);\r\n}\r\n\r\n.component-item.selected {\r\n    border-color: #10b981;\r\n    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.2);\r\n    background: rgba(20, 40, 30, 0.7);\r\n}\r\n\r\n.component-content {\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 15px;\r\n}\r\n\r\n.component-icon {\r\n    width: 28px;\r\n    height: 28px;\r\n    background: #e8e1f5;\r\n    border-radius: 8px;\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n    color: #7d66c5;\r\n    font-weight: bold;\r\n    font-size: 1.2rem;\r\n}\r\n\r\n.component-name {\r\n    color: #ffffff;\r\n    font-size: 1.2rem;\r\n    font-weight: 600;\r\n}\r\n\r\n.component-required {\r\n    background: #f0f0f7;\r\n    color: #7d66c5;\r\n    border-radius: 6px;\r\n    padding: 4px 10px;\r\n    font-size: 0.9rem;\r\n    font-weight: 500;\r\n    margin-left: 10px;\r\n}\r\n\r\n.btn {\r\n    flex: 0;\r\n    background: #f0f0f7;\r\n    color: #7d66c5;\r\n    border: 1px solid #e0e0e0;\r\n    border-radius: 6px;\r\n    padding: 10px;\r\n    font-weight: 500;\r\n    cursor: pointer;\r\n    transition: all 0.2s ease;\r\n    font-size: 0.95rem;\r\n    text-align: center;\r\n    min-height: 45px;\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n    text-decoration: none;\r\n    text-transform: uppercase;\r\n    min-width: 100px;\r\n}\r\n\r\n.btn:hover {\r\n    background: #e8e1f5;\r\n    color: #4a4a6a;\r\n}\r\n\r\n.btn:active {\r\n    background: #d8d0f0;\r\n    transform: translateY(1px);\r\n}\r\n\r\n.btn-primary {\r\n    background: linear-gradient(135deg, #7d66c5 0%, #6a55b2 100%);\r\n    color: #ffffff;\r\n    border: none;\r\n}\r\n\r\n.btn-primary:hover {\r\n    background: linear-gradient(135deg, #8b76d0 0%, #7865c0 100%);\r\n}\r\n\r\n/* Нижняя панель управления */\r\n.config-controls {\r\n    display: flex;\r\n    gap: 20px;\r\n    margin-top: 30px;\r\n    justify-content: center;\r\n}\r\n\r\n.btn-lg {\r\n    padding: 12px 25px;\r\n    font-size: 1.1rem;\r\n    min-width: 180px;\r\n}\r\n\r\n/* Футер сайта */\r\n.site-footer {\r\n    width: 100%;\r\n    max-width: 1200px;\r\n    background: rgba(15, 15, 35, 0.7);\r\n    padding: 15px 30px;\r\n    border-top: 1px solid rgba(157, 78, 221, 0.3);\r\n    border-radius: 12px;\r\n    font-size: 1.05rem;\r\n    color: #666;\r\n    text-align: center;\r\n    margin: 40px auto 0;\r\n    position: relative;\r\n    z-index: 10;\r\n    margin-top: 20px;\r\n    font-weight: 300;\r\n}\r\n\r\n.status-indicator {\r\n    display: inline-block;\r\n    width: 10px;\r\n    height: 10px;\r\n    background: #7d66c5;\r\n    border-radius: 50%;\r\n    margin-right: 10px;\r\n    box-shadow: 0 0 8px rgba(125, 102, 197, 0.6);\r\n    animation: pulse 2s infinite;\r\n}\r\n\r\n@keyframes pulse {\r\n    0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(125, 102, 197, 0.6); }\r\n    50% { opacity: 0.7; box-shadow: 0 0 12px rgba(125, 102, 197, 0.9); }\r\n}\r\n\r\n/* Адаптивность */\r\n@media (max-width: 768px) {\r\n    .page-title {\r\n        font-size: 1.8rem;\r\n    }\r\n\r\n    .block-title h2 {\r\n        font-size: 1.4rem;\r\n    }\r\n\r\n    .component-name {\r\n        font-size: 1.1rem;\r\n    }\r\n\r\n    .component-icon {\r\n        width: 24px;\r\n        height: 24px;\r\n        font-size: 1rem;\r\n    }\r\n\r\n    .btn {\r\n        padding: 8px;\r\n        font-size: 0.9rem;\r\n    }\r\n}\r\n\r\n@media (max-width: 480px) {\r\n    .page-title {\r\n        font-size: 1.6rem;\r\n    }\r\n\r\n    .btn-lg {\r\n        padding: 10px 20px;\r\n        font-size: 1rem;\r\n        min-width: 160px;\r\n    }\r\n}
