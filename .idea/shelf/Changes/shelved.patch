<+>/* ========================================\r\n   COMPONENTS.CSS - СТИЛИ СТРАНИЦЫ КОМПЛЕКТУЮЩИХ\r\n   ======================================== */\r\n\r\n/* Page Header */\r\n.page-header {\r\n    text-align: center;\r\n    padding: 40px 0 30px;\r\n}\r\n\r\n.page-title {\r\n    font-size: 4rem;\r\n    font-weight: 800;\r\n    color: #ffffff;\r\n    background: linear-gradient(to right, #ffffff, #e0e0ff);\r\n    -webkit-background-clip: text;\r\n    -webkit-text-fill-color: transparent;\r\n    background-clip: text;\r\n    margin-bottom: 10px;\r\n}\r\n\r\n.page-subtitle {\r\n    font-size: 1.4rem;\r\n    color: #b0b0d0;\r\n    font-weight: 300;\r\n}\r\n\r\n/* Catalog Container */\r\n.catalog-container {\r\n    display: flex;\r\n    gap: 30px;\r\n    margin: 40px 0;\r\n    align-items: flex-start;\r\n}\r\n\r\n/* Left Sidebar Filters */\r\n.filters-sidebar {\r\n    width: 280px;\r\n    flex-shrink: 0;\r\n    background: rgba(25, 25, 50, 0.75);\r\n    border: 1px solid rgba(157, 78, 221, 0.3);\r\n    border-radius: 16px;\r\n    padding: 25px;\r\n    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);\r\n    position: sticky;\r\n    top: 100px;\r\n    max-height: calc(100vh - 120px);\r\n    overflow-y: auto;\r\n}\r\n\r\n.filters-sidebar::-webkit-scrollbar {\r\n    width: 6px;\r\n}\r\n\r\n.filters-sidebar::-webkit-scrollbar-track {\r\n    background: rgba(157, 78, 221, 0.1);\r\n    border-radius: 3px;\r\n}\r\n\r\n.filters-sidebar::-webkit-scrollbar-thumb {\r\n    background: rgba(157, 78, 221, 0.5);\r\n    border-radius: 3px;\r\n}\r\n\r\n.filters-header {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    margin-bottom: 25px;\r\n    padding-bottom: 15px;\r\n    border-bottom: 1px solid rgba(157, 78, 221, 0.3);\r\n}\r\n\r\n.filters-title {\r\n    font-size: 1.3rem;\r\n    color: #ffffff;\r\n    font-weight: 700;\r\n    letter-spacing: 1px;\r\n}\r\n\r\n.filters-reset {\r\n    background: transparent;\r\n    border: 1px solid rgba(157, 78, 221, 0.4);\r\n    color: #9d4edd;\r\n    padding: 6px 12px;\r\n    border-radius: 6px;\r\n    font-size: 0.8rem;\r\n    cursor: pointer;\r\n    transition: all 0.3s ease;\r\n    text-transform: uppercase;\r\n    font-weight: 600;\r\n}\r\n\r\n.filters-reset:hover {\r\n    background: rgba(157, 78, 221, 0.2);\r\n    border-color: #9d4edd;\r\n}\r\n\r\n.filter-section {\r\n    margin-bottom: 25px;\r\n    padding-bottom: 20px;\r\n    border-bottom: 1px solid rgba(157, 78, 221, 0.15);\r\n}\r\n\r\n.filter-section:last-of-type {\r\n    border-bottom: none;\r\n}\r\n\r\n.filter-label {\r\n    display: block;\r\n    color: #c5c5e0;\r\n    font-size: 0.95rem;\r\n    font-weight: 600;\r\n    margin-bottom: 12px;\r\n    text-transform: uppercase;\r\n    letter-spacing: 0.5px;\r\n}\r\n\r\n.filter-search {\r\n    width: 100%;\r\n    background: rgba(30, 30, 60, 0.8);\r\n    border: 1px solid rgba(157, 78, 221, 0.3);\r\n    border-radius: 10px;\r\n    padding: 12px 15px;\r\n    color: #e0e0ff;\r\n    font-size: 0.95rem;\r\n    outline: none;\r\n    transition: all 0.3s ease;\r\n}\r\n\r\n.filter-search:focus {\r\n    border-color: #9d4edd;\r\n    box-shadow: 0 0 0 3px rgba(157, 78, 221, 0.2);\r\n}\r\n\r\n.filter-search::placeholder {\r\n    color: #6a6a8a;\r\n}\r\n\r\n.filter-checkboxes {\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: 10px;\r\n}\r\n\r\n.checkbox-label {\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 10px;\r\n    color: #b0b0d0;\r\n    font-size: 0.95rem;\r\n    cursor: pointer;\r\n    position: relative;\r\n    padding-left: 28px;\r\n}\r\n\r\n.checkbox-label:hover {\r\n    color: #ffffff;\r\n}\r\n\r\n.checkbox-label input {\r\n    position: absolute;\r\n    opacity: 0;\r\n    cursor: pointer;\r\n}\r\n\r\n.checkmark {\r\n    position: absolute;\r\n    left: 0;\r\n    top: 50%;\r\n    transform: translateY(-50%);\r\n    height: 18px;\r\n    width: 18px;\r\n    background: rgba(30, 30, 60, 0.8);\r\n    border: 1px solid rgba(157, 78, 221, 0.4);\r\n    border-radius: 4px;\r\n    transition: all 0.3s ease;\r\n}\r\n\r\n.checkbox-label:hover .checkmark {\r\n    border-color: #9d4edd;\r\n}\r\n\r\n.checkbox-label input:checked ~ .checkmark {\r\n    background: linear-gradient(135deg, #9d4edd 0%, #7e3cc5 100%);\r\n    border-color: #9d4edd;\r\n}\r\n\r\n.checkmark:after {\r\n    content: \"\";\r\n    position: absolute;\r\n    display: none;\r\n    left: 6px;\r\n    top: 3px;\r\n    width: 4px;\r\n    height: 8px;\r\n    border: solid white;\r\n    border-width: 0 2px 2px 0;\r\n    transform: rotate(45deg);\r\n}\r\n\r\n.checkbox-label input:checked ~ .checkmark:after {\r\n    display: block;\r\n}\r\n\r\n.price-inputs {\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 10px;\r\n    margin-bottom: 15px;\r\n}\r\n\r\n.price-from, .price-to {\r\n    flex: 1;\r\n    background: rgba(30, 30, 60, 0.8);\r\n    border: 1px solid rgba(157, 78, 221, 0.3);\r\n    border-radius: 8px;\r\n    padding: 10px 12px;\r\n    color: #e0e0ff;\r\n    font-size: 0.9rem;\r\n    outline: none;\r\n}\r\n\r\n.price-from:focus, .price-to:focus {\r\n    border-color: #9d4edd;\r\n    box-shadow: 0 0 0 3px rgba(157, 78, 221, 0.2);\r\n}\r\n\r\n.price-separator {\r\n    color: #6a6a8a;\r\n}\r\n\r\n.price-range {\r\n    width: 100%;\r\n    height: 6px;\r\n    border-radius: 3px;\r\n    background: rgba(30, 30, 60, 0.8);\r\n    outline: none;\r\n    -webkit-appearance: none;\r\n}\r\n\r\n.price-range::-webkit-slider-thumb {\r\n    -webkit-appearance: none;\r\n    width: 18px;\r\n    height: 18px;\r\n    border-radius: 50%;\r\n    background: linear-gradient(135deg, #9d4edd 0%, #7e3cc5 100%);\r\n    cursor: pointer;\r\n    box-shadow: 0 0 10px rgba(157, 78, 221, 0.5);\r\n}\r\n\r\n.filter-apply-btn {\r\n    width: 100%;\r\n    background: linear-gradient(135deg, #9d4edd 0%, #7e3cc5 100%);\r\n    color: #ffffff;\r\n    border: none;\r\n    border-radius: 10px;\r\n    padding: 14px 25px;\r\n    font-size: 1rem;\r\n    font-weight: 700;\r\n    cursor: pointer;\r\n    transition: all 0.3s ease;\r\n    text-transform: uppercase;\r\n    letter-spacing: 1px;\r\n}\r\n\r\n.filter-apply-btn:hover {\r\n    transform: translateY(-2px);\r\n    box-shadow: 0 8px 25px rgba(157, 78, 221, 0.45);\r\n}\r\n\r\n/* Components Wrapper */\r\n.components-wrapper {\r\n    flex: 1;\r\n    min-width: 0;\r\n}\r\n\r\n.components-toolbar {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    background: rgba(25, 25, 50, 0.75);\r\n    border: 1px solid rgba(157, 78, 221, 0.3);\r\n    border-radius: 12px;\r\n    padding: 15px 25px;\r\n    margin-bottom: 25px;\r\n}\r\n\r\n.components-count {\r\n    color: #b0b0d0;\r\n    font-size: 1rem;\r\n}\r\n\r\n.components-count strong {\r\n    color: #9d4edd;\r\n}\r\n\r\n.components-sort {\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 12px;\r\n}\r\n\r\n.components-sort label {\r\n    color: #c5c5e0;\r\n    font-size: 0.95rem;\r\n}\r\n\r\n.sort-select {\r\n    background: rgba(30, 30, 60, 0.8);\r\n    border: 1px solid rgba(157, 78, 221, 0.3);\r\n    border-radius: 8px;\r\n    padding: 10px 15px;\r\n    color: #e0e0ff;\r\n    font-size: 0.95rem;\r\n    outline: none;\r\n    cursor: pointer;\r\n}\r\n\r\n.sort-select:focus {\r\n    border-color: #9d4edd;\r\n}\r\n\r\n.sort-select option {\r\n    background: #1a1a2e;\r\n    color: #e0e0ff;\r\n}\r\n\r\n/* Components Grid */\r\n.components-grid {\r\n    display: grid;\r\n    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\r\n    gap: 25px;\r\n}\r\n\r\n.component-card {\r\n    background: rgba(35, 35, 70, 0.65);\r\n    border: 1px solid rgba(157, 78, 221, 0.25);\r\n    border-radius: 16px;\r\n    overflow: hidden;\r\n    transition: all 0.4s ease;\r\n    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);\r\n    display: flex;\r\n    flex-direction: column;\r\n}\r\n\r\n.component-card:hover {\r\n    transform: translateY(-8px);\r\n    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4), 0 0 25px rgba(157, 78, 221, 0.15);\r\n    border-color: rgba(157, 78, 221, 0.45);\r\n}\r\n\r\n.component-image {\r\n    position: relative;\r\n    height: 180px;\r\n    background: rgba(20, 20, 40, 0.8);\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n}\r\n\r\n.image-placeholder {\r\n    width: 100px;\r\n    height: 100px;\r\n    background: linear-gradient(135deg, rgba(157, 78, 221, 0.3) 0%, rgba(99, 102, 241, 0.3) 100%);\r\n    border-radius: 50%;\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n    font-size: 2.5rem;\r\n    font-weight: 700;\r\n    color: #ffffff;\r\n    border: 3px solid rgba(157, 78, 221, 0.5);\r\n}\r\n\r\n.out-of-stock {\r\n    position: absolute;\r\n    top: 10px;\r\n    right: 10px;\r\n    background: rgba(255, 82, 82, 0.9);\r\n    color: #ffffff;\r\n    padding: 5px 10px;\r\n    border-radius: 5px;\r\n    font-size: 0.7rem;\r\n    font-weight: 600;\r\n}\r\n\r\n.component-badge {\r\n    position: absolute;\r\n    top: 10px;\r\n    left: 10px;\r\n    background: linear-gradient(135deg, #10b981 0%, #059669 100%);\r\n    color: #ffffff;\r\n    padding: 5px 10px;\r\n    border-radius: 5px;\r\n    font-size: 0.7rem;\r\n    font-weight: 700;\r\n}\r\n\r\n.component-info {\r\n    padding: 18px;\r\n    flex-grow: 1;\r\n}\r\n\r\n.component-name {\r\n    font-size: 1.2rem;\r\n    color: #ffffff;\r\n    font-weight: 700;\r\n    margin-bottom: 6px;\r\n    line-height: 1.4;\r\n}\r\n\r\n.component-category {\r\n    font-size: 0.9rem;\r\n    color: #9d4edd;\r\n    font-weight: 500;\r\n    margin-bottom: 4px;\r\n}\r\n\r\n.component-manufacturer {\r\n    font-size: 0.85rem;\r\n    color: #6a6a8a;\r\n}\r\n\r\n.component-price {\r\n    padding: 18px;\r\n    border-top: 1px solid rgba(157, 78, 221, 0.2);\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    background: rgba(20, 20, 40, 0.5);\r\n}\r\n\r\n.price-value {\r\n    font-size: 1.4rem;\r\n    color: #10b981;\r\n    font-weight: 700;\r\n}\r\n\r\n.add-to-cart-btn {\r\n    background: linear-gradient(135deg, #9d4edd 0%, #7e3cc5 100%);\r\n    color: #ffffff;\r\n    border: none;\r\n    border-radius: 8px;\r\n    padding: 10px 18px;\r\n    font-size: 0.85rem;\r\n    font-weight: 600;\r\n    cursor: pointer;\r\n    transition: all 0.3s ease;\r\n    text-transform: uppercase;\r\n}\r\n\r\n.add-to-cart-btn:hover {\r\n    transform: translateY(-2px);\r\n    box-shadow: 0 6px 20px rgba(157, 78, 221, 0.4);\r\n}\r\n\r\n.add-to-cart-btn.disabled {\r\n    background: rgba(100, 100, 100, 0.5);\r\n    cursor: not-allowed;\r\n    opacity: 0.6;\r\n}\r\n\r\n.add-to-cart-btn.disabled:hover {\r\n    transform: none;\r\n    box-shadow: none;\r\n}\r\n\r\n/* Pagination */\r\n.pagination-section {\r\n    margin: 40px 0 60px;\r\n}\r\n\r\n.pagination {\r\n    display: flex;\r\n    justify-content: center;\r\n    gap: 10px;\r\n    flex-wrap: wrap;\r\n}\r\n\r\n.page-link {\r\n    background: rgba(35, 35, 70, 0.65);\r\n    border: 1px solid rgba(157, 78, 221, 0.25);\r\n    color: #c5c5e0;\r\n    padding: 12px 20px;\r\n    border-radius: 10px;\r\n    text-decoration: none;\r\n    font-weight: 500;\r\n    transition: all 0.3s ease;\r\n    cursor: pointer;\r\n}\r\n\r\n.page-link:hover, .page-link.active {\r\n    background: linear-gradient(135deg, #9d4edd 0%, #7e3cc5 100%);\r\n    color: #ffffff;\r\n    border-color: #9d4edd;\r\n}\r\n\r\n/* Responsive */\r\n@media (max-width: 1024px) {\r\n    .catalog-container {\r\n        flex-direction: column;\r\n    }\r\n\r\n    .filters-sidebar {\r\n        width: 100%;\r\n        position: relative;\r\n        top: 0;\r\n        max-height: none;\r\n    }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n    .page-title {\r\n        font-size: 2.8rem;\r\n    }\r\n\r\n    .page-subtitle {\r\n        font-size: 1.1rem;\r\n    }\r\n\r\n    .components-toolbar {\r\n        flex-direction: column;\r\n        gap: 15px;\r\n        align-items: flex-start;\r\n    }\r\n\r\n    .components-sort {\r\n        width: 100%;\r\n    }\r\n\r\n    .sort-select {\r\n        flex: 1;\r\n    }\r\n\r\n    .components-grid {\r\n        grid-template-columns: 1fr;\r\n    }\r\n\r\n    .pagination {\r\n        gap: 8px;\r\n    }\r\n\r\n    .page-link {\r\n        padding: 10px 15px;\r\n        font-size: 0.9rem;\r\n    }\r\n}\r\n\r\n@media (max-width: 480px) {\r\n    .filters-sidebar {\r\n        padding: 20px;\r\n    }\r\n\r\n    .filters-header {\r\n        flex-direction: column;\r\n        gap: 10px;\r\n        align-items: flex-start;\r\n    }\r\n\r\n    .filters-reset {\r\n        width: 100%;\r\n    }\r\n\r\n    .price-inputs {\r\n        flex-direction: column;\r\n        gap: 8px;\r\n    }\r\n\r\n    .component-price {\r\n        flex-direction: column;\r\n        gap: 12px;\r\n        align-items: flex-start;\r\n    }\r\n\r\n    .add-to-cart-btn {\r\n        width: 100%;\r\n    }\r\n}
