<+>/* ========================================\r\n   BASE.CSS - ОБЩИЕ СТИЛИ\r\n   ======================================== */\r\n\r\n/* ===== ГЛОБАЛЬНЫЕ СТИЛИ ===== */\r\n* {\r\n    margin: 0;\r\n    padding: 0;\r\n    box-sizing: border-box;\r\n}\r\n\r\nbody {\r\n    background: linear-gradient(135deg, #0a0a12 0%, #1a1a2e 100%);\r\n    color: #e0e0ff;\r\n    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\r\n    overflow-x: hidden;\r\n    line-height: 1.6;\r\n    min-height: 100vh;\r\n    position: relative;\r\n}\r\n\r\n/* ===== КОСМИЧЕСКИЙ ФОН ===== */\r\n.cosmic-bg {\r\n    position: fixed;\r\n    top: 0;\r\n    left: 0;\r\n    width: 100%;\r\n    height: 100%;\r\n    background: radial-gradient(\r\n        ellipse at center,\r\n        rgba(15, 15, 30, 0.9) 0%,\r\n        rgba(10, 10, 18, 0.95) 70%,\r\n        rgba(5, 5, 12, 1) 100%\r\n    );\r\n    z-index: -3;\r\n}\r\n\r\n.stars {\r\n    position: fixed;\r\n    top: 0;\r\n    left: 0;\r\n    width: 100%;\r\n    height: 100%;\r\n    z-index: -2;\r\n}\r\n\r\n.star {\r\n    position: absolute;\r\n    background: rgba(255, 255, 255, 0.8);\r\n    border-radius: 50%;\r\n    animation: twinkle 4s infinite;\r\n}\r\n\r\n@keyframes twinkle {\r\n    0%, 100% { opacity: 0.2; transform: scale(1); }\r\n    50% { opacity: 1; transform: scale(1.1); }\r\n}\r\n\r\n.nebula {\r\n    position: fixed;\r\n    border-radius: 50%;\r\n    filter: blur(60px);\r\n    z-index: -1;\r\n    opacity: 0.25;\r\n}\r\n\r\n.nebula-1 {\r\n    top: 15%; left: 10%; width: 400px; height: 400px;\r\n    background: radial-gradient(circle, #9d4edd 0%, transparent 70%);\r\n}\r\n\r\n.nebula-2 {\r\n    bottom: 10%; right: 15%; width: 350px; height: 350px;\r\n    background: radial-gradient(circle, #6366f1 0%, transparent 70%);\r\n}\r\n\r\n.nebula-3 {\r\n    top: 60%; left: 65%; width: 300px; height: 300px;\r\n    background: radial-gradient(circle, #ff5eda 0%, transparent 70%);\r\n}\r\n\r\n/* ===== HEADER ===== */\r\n.site-header {\r\n    width: 95%;\r\n    max-width: 1200px;\r\n    background: rgba(20, 20, 40, 0.85);\r\n    border: 2px solid rgba(157, 78, 221, 0.6);\r\n    border-radius: 16px;\r\n    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5), inset 0 0 20px rgba(157, 78, 221, 0.15);\r\n    padding: 15px 30px;\r\n    margin: 20px auto;\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    z-index: 10;\r\n    position: relative;\r\n}\r\n\r\n.site-title {\r\n    color: #ffffff;\r\n    font-size: 1.6rem;\r\n    font-weight: 700;\r\n    letter-spacing: 1px;\r\n    text-transform: uppercase;\r\n}\r\n\r\n.site-title::before {\r\n    content: \"\";\r\n    display: inline-block;\r\n    width: 8px;\r\n    height: 8px;\r\n    background: #10b981;\r\n    border-radius: 50%;\r\n    margin-right: 12px;\r\n    box-shadow: 0 0 8px rgba(16, 185, 129, 0.6);\r\n}\r\n\r\n.nav-menu {\r\n    display: flex;\r\n    gap: 25px;\r\n}\r\n\r\n.nav-link {\r\n    color: #c5c5e0;\r\n    text-decoration: none;\r\n    font-weight: 500;\r\n    font-size: 1.05rem;\r\n    padding: 8px 12px;\r\n    transition: all 0.3s ease;\r\n    border-radius: 8px;\r\n}\r\n\r\n.nav-link:hover, .nav-link.active {\r\n    color: #ffffff;\r\n    background: rgba(157, 78, 221, 0.25);\r\n}\r\n\r\n.site-controls {\r\n    display: flex;\r\n    gap: 10px;\r\n}\r\n\r\n.control-btn {\r\n    width: 14px;\r\n    height: 14px;\r\n    border-radius: 50%;\r\n    border: 2px solid rgba(255, 255, 255, 0.3);\r\n    transition: all 0.3s ease;\r\n}\r\n\r\n.control-btn.close:hover { background: #ff5252; border-color: #ff1a1a; }\r\n.control-btn.minimize:hover { background: #ffcc00; border-color: #cc9900; }\r\n.control-btn.maximize:hover { background: #2ecc40; border-color: #1a8c26; }\r\n\r\n/* ===== MAIN CONTENT ===== */\r\n.main-content {\r\n    width: 95%;\r\n    max-width: 1200px;\r\n    margin: 0 auto;\r\n    position: relative;\r\n    z-index: 5;\r\n}\r\n\r\n/* ===== FOOTER ===== */\r\n.site-footer {\r\n    width: 95%;\r\n    max-width: 1200px;\r\n    background: rgba(15, 15, 35, 0.7);\r\n    padding: 22px 30px;\r\n    border-top: 1px solid rgba(157, 78, 221, 0.3);\r\n    border-radius: 16px;\r\n    font-size: 1.05rem;\r\n    color: #b0b0d0;\r\n    text-align: center;\r\n    margin: 0 auto 40px;\r\n    position: relative;\r\n    z-index: 10;\r\n}\r\n\r\n.status-indicator {\r\n    display: inline-block;\r\n    width: 10px;\r\n    height: 10px;\r\n    background: #10b981;\r\n    border-radius: 50%;\r\n    margin-right: 10px;\r\n    box-shadow: 0 0 8px rgba(16, 185, 129, 0.6);\r\n    animation: pulse 2s infinite;\r\n}\r\n\r\n@keyframes pulse {\r\n    0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(16, 185, 129, 0.6); }\r\n    50% { opacity: 0.7; box-shadow: 0 0 12px rgba(16, 185, 129, 0.9); }\r\n}\r\n\r\n/* ===== ANIMATIONS ===== */\r\n@keyframes fadeInUp {\r\n    from { opacity: 0; transform: translateY(30px); }\r\n    to { opacity: 1; transform: translateY(0); }\r\n}\r\n\r\n.fade-in {\r\n    animation: fadeInUp 0.8s ease-out forwards;\r\n}\r\n\r\n/* ===== RESPONSIVE ===== */\r\n@media (max-width: 768px) {\r\n    .site-header {\r\n        flex-direction: column;\r\n        gap: 15px;\r\n    }\r\n\r\n    .nav-menu {\r\n        flex-wrap: wrap;\r\n        justify-content: center;\r\n        gap: 15px;\r\n    }\r\n\r\n    .nav-link {\r\n        font-size: 0.95rem;\r\n        padding: 6px 10px;\r\n    }\r\n}
