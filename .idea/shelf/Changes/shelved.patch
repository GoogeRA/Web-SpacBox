 <label class=\"checkbox-label\">\r\n                    <input type=\"checkbox\" name=\"category\" value=\"ram\">\r\n                    <span class=\"checkmark\"></span>Оперативная память\r\n                </label>\r\n                <label class=\"checkbox-label\">\r\n                    <input type=\"checkbox\" name=\"category\" value=\"ssd\">\r\n                    <span class=\"checkmark\"></span>SSD накопители\r\n                </label>\r\n                <label class=\"checkbox-label\">\r\n                    <input type=\"checkbox\" name=\"category\" value=\"psu\">\r\n                    <span class=\"checkmark\"></span>Блоки питания\r\n                </label>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Brand -->\r\n        <div class=\"filter-section\">\r\n            <label class=\"filter-label\">Производитель</label>\r\n            <div class=\"filter-checkboxes\">\r\n                <label class=\"checkbox-label\">\r\n                    <input type=\"checkbox\" name=\"brand\" value=\"nvidia\">\r\n                    <span class=\"checkmark\"></span>NVIDIA\r\n                </label>\r\n                <label class=\"checkbox-label\">\r\n                    <input type=\"checkbox\" name=\"brand\" value=\"amd\">\r\n                    <span class=\"checkmark\"></span>AMD\r\n                </label>\r\n                <label class=\"checkbox-label\">\r\n                    <input type=\"checkbox\" name=\"brand\" value=\"intel\">\r\n                    <span class=\"checkmark\"></span>Intel\r\n                </label>\r\n                <label class=\"checkbox-label\">\r\n                    <input type=\"checkbox\" name=\"brand\" value=\"asus\">\r\n                    <span class=\"checkmark\"></span>ASUS\r\n                </label>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Price -->\r\n        <div class=\"filter-section\">\r\n            <label class=\"filter-label\">Цена, ₽</label>\r\n            <div class=\"price-inputs\">\r\n                <input type=\"number\" class=\"price-from\" placeholder=\"От\">\r\n                <span class=\"price-separator\">—</span>\r\n                <input type=\"number\" class=\"price-to\" placeholder=\"До\">\r\n            </div>\r\n            <input type=\"range\" class=\"price-range\" min=\"0\" max=\"200000\" step=\"1000\" value=\"200000\">\r\n        </div>\r\n\r\n        <!-- Apply Button -->\r\n        <button class=\"filter-apply-btn\" onclick=\"applyFilters()\">ПРИМЕНИТЬ</button>\r\n    </aside>\r\n\r\n    <!-- Components Wrapper -->\r\n    <div class=\"components-wrapper\">\r\n        <!-- Toolbar -->\r\n        <div class=\"components-toolbar\">\r\n            <span class=\"components-count\">Найдено: <strong>{{ total_count }}</strong></span>\r\n            <div class=\"components-sort\">\r\n                <label>Сортировать:</label>\r\n                <select class=\"sort-select\">\r\n                    <option value=\"popular\">По популярности</option>\r\n                    <option value=\"price_asc\">По цене (возрастание)</option>\r\n                    <option value=\"price_desc\">По цене (убывание)</option>\r\n                </select>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Components Grid -->\r\n        <section class=\"components-section\">\r\n            <div class=\"components-grid\">\r\n                {% for component in components %}\r\n                <div class=\"component-card fade-in\">\r\n                    <div class=\"component-image\">\r\n                        <div class=\"image-placeholder\">{{ component.manufacturer|first }}</div>\r\n                        {% if component.is_hit %}<div class=\"component-badge\">HIT</div>{% endif %}\r\n                        {% if not component.in_stock %}<div class=\"out-of-stock\">НЕТ В НАЛИЧИИ</div>{% endif %}\r\n                    </div>\r\n                    <div class=\"component-info\">\r\n                        <h3 class=\"component-name\">{{ component.name }}</h3>\r\n                        <p class=\"component-category\">{{ component.category }}</p>\r\n                        <p class=\"component-manufacturer\">{{ component.manufacturer }}</p>\r\n                    </div>\r\n                    <div class=\"component-price\">\r\n                        <span class=\"price-value\">{{ component.price|floatformat:0 }} ₽</span>\r\n                        {% if component.in_stock %}\r\n                        <button class=\"add-to-cart-btn\" onclick=\"addToCart('{{ component.name }}')\">В СБОРКУ</button>\r\n                        {% else %}\r\n                        <button class=\"add-to-cart-btn disabled\" disabled>ОЖИДАЕТСЯ</button>\r\n                        {% endif %}\r\n                    </div>\r\n                </div>\r\n                {% endfor %}\r\n            </div>\r\n        </section>\r\n\r\n        <!-- Pagination -->\r\n        <section class=\"pagination-section\">\r\n            <div class=\"pagination\">\r\n                <a class=\"page-link\">← Назад</a>\r\n                <a class=\"page-link active\">1</a>\r\n                <a class=\"page-link\">2</a>\r\n                <a class=\"page-link\">3</a>\r\n                <a class=\"page-link\">...</a>\r\n                <a class=\"page-link\">10</a>\r\n                <a class=\"page-link\">Вперёд →</a>\r\n            </div>\r\n        </section>\r\n    </div>\r\n</section>\r\n\r\n<script>\r\n    function addToCart(name) { alert('✅ \"' + name + '\" добавлен в сборку!'); }\r\n    function resetFilters() {\r\n        document.querySelectorAll('.filter-checkboxes input').forEach(cb => cb.checked = false);\r\n        document.querySelectorAll('.price-from, .price-to, .filter-search').forEach(i => i.value = '');\r\n        alert('Фильтры сброшены');\r\n    }\r\n    function applyFilters() { alert('Фильтры применены!'); }\r\n</script>\r\n{% endblock %}
