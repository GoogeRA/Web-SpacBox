+/* ========================================
+PROFILE.CSS - СТИЛИ ЛИЧНОГО КАБИНЕТА
+======================================== */
+
+/* Page Header */
+.page-header {
+    text-align: center;
+    padding: 20px 0 30px;
+}
+
+.page-title {
+    font-size: 4rem;
+    font-weight: 800;
+    color: #ffffff;
+    background: linear-gradient(to right, #ffffff, #e0e0ff);
+    -webkit-background-clip: text;
+    -webkit-text-fill-color: transparent;
+    background-clip: text;
+    margin-bottom: 10px;
+}
+
+.page-subtitle {
+    font-size: 1.4rem;
+    color: #b0b0d0;
+    font-weight: 300;
+}
+
+/* В начало файла style_profile.css */
+.profile-container {
+    display: flex;
+    gap: 30px;
+    margin: 40px 0;
+    align-items: flex-start;
+    padding-top: 20px;  /* ← Дополнительный отступ */
+}
+
+/* Sidebar */
+.profile-sidebar {
+    width: 320px;
+    flex-shrink: 0;
+    background: rgba(25, 25, 50, 0.75);
+    border: 1px solid rgba(157, 78, 221, 0.3);
+    border-radius: 16px;
+    padding: 25px;
+    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
+    position: sticky;
+    top: 100px;
+    max-height: calc(100vh - 120px);
+    overflow-y: auto;
+}
+
+.profile-sidebar::-webkit-scrollbar {
+    width: 6px;
+}
+
+.profile-sidebar::-webkit-scrollbar-track {
+    background: rgba(157, 78, 221, 0.1);
+    border-radius: 3px;
+}
+
+.profile-sidebar::-webkit-scrollbar-thumb {
+    background: rgba(157, 78, 221, 0.5);
+    border-radius: 3px;
+}
+
+/* User Info Card */
+.user-info-card {
+    background: rgba(35, 35, 70, 0.65);
+    border: 1px solid rgba(157, 78, 221, 0.25);
+    border-radius: 12px;
+    padding: 20px;
+    margin-bottom: 25px;
+    display: flex;
+    align-items: center;
+    gap: 15px;
+}
+
+.user-avatar {
+    width: 60px;
+    height: 60px;
+    border-radius: 50%;
+    background: linear-gradient(135deg, #9d4edd 0%, #7e3cc5 100%);
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    flex-shrink: 0;
+    border: 2px solid rgba(157, 78, 221, 0.5);
+}
+
+.avatar-placeholder {
+    font-size: 1.8rem;
+    font-weight: 700;
+    color: #ffffff;
+}
+
+.user-details {
+    flex: 1;
+    min-width: 0;
+}
+
+.user-name {
+    font-size: 1.2rem;
+    color: #ffffff;
